    {
      "name": "F1 – Auth & RBAC",
      "item": [

        {
          "name": "TC-API-AUTH-01 – Valid login → get ID token",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "// BƯỚC 2: CHECK INTERFACE",
            "var j = pm.response.json();",
            "pm.test('TC-API-AUTH-01 | [UI] Status 200', () => pm.response.to.have.status(200));",
            "pm.test('TC-API-AUTH-01 | [UI] idToken present', () => { pm.expect(j).to.have.property('idToken'); pm.expect(j.idToken).to.be.a('string').and.not.empty; });",
            "pm.test('TC-API-AUTH-01 | [UI] refreshToken present', () => pm.expect(j).to.have.property('refreshToken'));",
            "pm.test('TC-API-AUTH-01 | [UI] localId present', () => pm.expect(j).to.have.property('localId'));",
            "// BƯỚC 3: CHECK DATABASE",
            "var token = j.idToken; var uid = j.localId;",
            "if (token && uid) {",
            "  pm.sendRequest({ url: pm.collectionVariables.get('baseFirestoreUrl') + '/users/' + uid, method: 'GET', header: { 'Authorization': 'Bearer ' + token } }, function(err, res) {",
            "    pm.test('TC-API-AUTH-01 | [DB] User document exists in Firestore', () => pm.expect(res.code).to.equal(200));",
            "    pm.test('TC-API-AUTH-01 | [DB] User has role field', () => { var doc = res.json(); pm.expect(doc.fields).to.have.property('role'); });",
            "  });",
            "}"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseAuthUrl}}:signInWithPassword?key={{apiKey}}", "host": ["{{baseAuthUrl}}:signInWithPassword"], "query": [{ "key": "key", "value": "{{apiKey}}" }] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{testPassword}}\",\n  \"returnSecureToken\": true\n}" }
          }
        },

        {
          "name": "TC-API-AUTH-02 – Wrong password → error",
