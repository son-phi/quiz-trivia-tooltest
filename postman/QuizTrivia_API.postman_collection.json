            "pm.test('TC-API-AUTH-02 | [UI] Status 400', () => pm.response.to.have.status(400));",
            "pm.test('TC-API-AUTH-02 | [UI] error field present', () => pm.expect(j).to.have.property('error'));",
            "pm.test('TC-API-AUTH-02 | [UI] error.message = INVALID_LOGIN_CREDENTIALS', () => {",
            "  var msg = j.error && j.error.message ? j.error.message : '';",
